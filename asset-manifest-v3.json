  "specialRules": {
    "customTheme": {
      "hasBuiltInAssets": false,
      "allowAllModels": true,
      "allowAllThemeCards": true,
      "requiresManualBrief": true,
      "requiresManualQuote": true,
      "customerCanUploadReference": true
    },
    "noThemeSpecificModelsFallback": {
      "whenThemeHasZeroModels": true,
      "allowAllModels": true
    }
  },
  "notes": [
    "All asset paths are relative to the GitHub repository root. Do not prepend 'Website Assets/'.",
    "Import/copy the assets into the Happy Kits project or its media storage. Do not depend on GitHub raw URLs as the permanent production image host.",
    "The real filenames 'Candy/Jolly Rancher Cherrry.png' and 'Candy/Maynards Puzzy Peaches.png' contain spelling errors; the manifest keeps those exact paths but uses corrected customer-facing labels.",
    "If a theme has zero model files, the builder must allow all active plaster models.",
    "Custom Theme has no built-in card, square preview, or name-label file. It uses a customer description/reference upload and allows all models/assets.",
    "Cowboy uses 'Themes/Cowboy/Cowboy Theme Card.png' as its full-size card asset."
  ],
  "repository": {
